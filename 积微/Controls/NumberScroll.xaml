<UserControl x:Class="积微.Controls.NumberScroll"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="70">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Button x:Name="UpButton" Grid.Row="0" Click="UpButton_Click"
                Width="{Binding DigitWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Height="20" BorderThickness="0"
                Background="Transparent" Foreground="#6B7280"
                Cursor="Hand" Opacity="0.3"
                Visibility="{Binding IsEditable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="M10,15 L20,5 L30,15" Stroke="#6B7280" StrokeThickness="2" 
                  Fill="Transparent" Stretch="Uniform" Width="24" Height="16" Opacity="0.3"/>
        </Button>
        
        <Border x:Name="NumberBorder" Grid.Row="1" ClipToBounds="True" 
                Background="#F3F4F6" CornerRadius="8"
                Width="{Binding DigitWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Height="{Binding DigitHeight, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <Canvas x:Name="NumbersCanvas" 
                    Width="{Binding DigitWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                    Height="{Binding DigitHeight, RelativeSource={RelativeSource AncestorType=UserControl}}">
            </Canvas>
        </Border>
        
        <Button x:Name="DownButton" Grid.Row="2" Click="DownButton_Click"
                Width="{Binding DigitWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                Height="20" BorderThickness="0"
                Background="Transparent" Foreground="#6B7280"
                Cursor="Hand" Opacity="0.3"
                Visibility="{Binding IsEditable, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}">
            <Path Data="M10,5 L20,15 L30,5" Stroke="#6B7280" StrokeThickness="2" 
                  Fill="Transparent" Stretch="Uniform" Width="24" Height="16" Opacity="0.3"/>
        </Button>
    </Grid>
</UserControl>
