<UserControl x:Class="积微.Controls.TimerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:积微.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="720"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             Loaded="UserControl_Loaded"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <DropShadowEffect x:Key="ButtonShadow" Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2"/>
        <DropShadowEffect x:Key="ButtonShadowHover" Color="#000000" Opacity="0.15" BlurRadius="12" ShadowDepth="3"/>
        
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="50" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Effect="{StaticResource ButtonShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{StaticResource ButtonShadowHover}"/>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="16" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="20,12"
                                Effect="{StaticResource ButtonShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{StaticResource ButtonShadowHover}"/>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="SmallIconButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HoverColor}"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="SeparatorTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0"/>
        </Style>
        <Style x:Key="UnitLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextTertiary}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="16" Background="{DynamicResource CardBackground}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                                Padding="16,12">
                            <ScrollViewer x:Name="PART_ContentHost" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
        
        <Style x:Key="CustomComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ToggleButton x:Name="ToggleButton"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="2"
                                              Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"
                                              Background="Transparent">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Padding="0"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="10,0,5,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>
                                
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Data="M0,3 L3,6 L6,3"
                                      Fill="{DynamicResource TextSecondary}"
                                      Margin="0,0,8,0"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Width="6"
                                      Height="6"
                                      IsHitTestVisible="False"/>
                                
                                <Popup x:Name="Popup"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource BorderColor}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" Opacity="0.1" ShadowDepth="2" Direction="270"/>
                                        </Border.Effect>
                                        <ScrollViewer Margin="0">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="CustomComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource HoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource Background}">
        <Button x:Name="ModeSwitchButton" Click="ModeSwitchButton_Click"
                Width="36" Height="36" 
                Background="{DynamicResource HoverColor}"
                Style="{StaticResource SmallIconButtonStyle}"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="10,10,10,0" ToolTip="切换到番茄钟模式">
            <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12.5,8.5L17,12L12.5,15.5V13H7V11H12.5V8.5Z" Fill="{DynamicResource TextSecondary}" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
        
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="680" Margin="20">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20" HorizontalAlignment="Center">
                <Button x:Name="StopwatchButton" Click="StopwatchButton_Click"
                        Style="{StaticResource ToggleButtonStyle}"
                        Background="#3B82F6" Foreground="White">
                    计时
                </Button>
                <Button x:Name="CountdownButton" Click="CountdownButton_Click"
                        Style="{StaticResource ToggleButtonStyle}"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}"
                        Margin="8,0,0,0">
                    倒计时
                </Button>
            </StackPanel>
            
            <TextBlock x:Name="SessionText" FontSize="14" Text="Stopwatch" 
                       HorizontalAlignment="Center" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,10"/>
            
            <Grid x:Name="TimerDisplayPanel" Margin="0,0,0,20" HorizontalAlignment="Stretch" Height="140">
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="天" Style="{StaticResource UnitLabelStyle}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <local:NumberScroll x:Name="Days1" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                        <local:NumberScroll x:Name="Days2" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                        <local:NumberScroll x:Name="Days3" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock Text="时" Style="{StaticResource UnitLabelStyle}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <local:NumberScroll x:Name="Hours1" MaxValue="2" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                            <local:NumberScroll x:Name="Hours2" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text=":" Style="{StaticResource SeparatorTextBlockStyle}" VerticalAlignment="Center" Margin="8,0,8,0"/>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock Text="分" Style="{StaticResource UnitLabelStyle}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <local:NumberScroll x:Name="Minutes1" MaxValue="5" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                            <local:NumberScroll x:Name="Minutes2" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text=":" Style="{StaticResource SeparatorTextBlockStyle}" VerticalAlignment="Center" Margin="8,0,8,0"/>

                    <StackPanel VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock Text="秒" Style="{StaticResource UnitLabelStyle}" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <local:NumberScroll x:Name="Seconds1" MaxValue="5" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                            <local:NumberScroll x:Name="Seconds2" MaxValue="9" FontSize="32" DigitHeight="50" DigitWidth="40"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
            
            <TextBlock x:Name="CurrentGoalText" Text="" FontSize="30" FontWeight="SemiBold" Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,15" MinHeight="28" Visibility="Hidden"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                <Button x:Name="ResetButton" Click="ResetButton_Click"
                        Width="44" Height="44" BorderThickness="0"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundButtonStyle}">
                    <Path Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="PlayPauseButton" Click="PlayPauseButton_Click"
                        Width="44" Height="44" BorderThickness="0"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundButtonStyle}"
                        Margin="12,0,0,0">
                    <Path x:Name="PlayPauseIcon" Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
                </Button>
                <Button x:Name="StopButton" Click="StopButton_Click"
                        Width="44" Height="44" BorderThickness="0"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundButtonStyle}"
                        Margin="12,0,0,0">
                    <Path Data="M6,6H18V18H6V6Z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button x:Name="WhiteNoiseButton" Click="WhiteNoiseButton_Click"
                        Width="44" Height="44" BorderThickness="0"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundButtonStyle}"
                        Margin="12,0,0,0" ToolTip="播放白噪音">
                    <Path x:Name="WhiteNoiseIcon" Data="M12,3C12.55,3 13,3.45 13,4C13,4.55 12.55,5 12,5C11.45,5 11,4.55 11,4C11,3.45 11.45,3 12,3M3,13H6V11H3V13M7,13H10V11H7V13M11,13H14V11H11V13M15,13H18V11H15V13M19,13H22V11H19V13M3,17H6V15H3V17M7,17H10V15H7V17M11,17H14V15H11V17M15,17H18V15H15V17M19,17H22V15H19V17M3,9H6V7H3V9M7,9H10V7H7V9M11,9H14V7H11V9M15,9H18V7H15V9M19,9H22V7H19V9Z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                
                <Button x:Name="SelectGoalButton" Width="32" Height="32" Background="{DynamicResource CardBackground}" Margin="0,0,8,0" ToolTip="选择目标" Style="{StaticResource SmallIconButtonStyle}" Click="SelectGoalButton_Click">
                    <Path Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z" Fill="{DynamicResource TextSecondary}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                
                <Button x:Name="ClearGoalButton" Width="32" Height="32" Background="{DynamicResource CardBackground}" Margin="0,0,8,0" ToolTip="清空当前目标" Style="{StaticResource SmallIconButtonStyle}" Click="ClearGoalButton_Click">
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="{DynamicResource TextSecondary}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                
                <Button x:Name="AddGoalButton" Width="32" Height="32" Background="{DynamicResource CardBackground}" ToolTip="添加目标" Style="{StaticResource SmallIconButtonStyle}" Click="AddGoalButton_Click">
                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="{DynamicResource TextSecondary}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
