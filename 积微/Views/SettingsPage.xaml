<UserControl x:Class="积微.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:积微.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="720">
    <UserControl.Resources>
        <converters:StringToUriConverter x:Key="StringToUriConverter"/>

        <Style x:Key="InteractiveCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" 
                                               To="0.08" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" 
                                               To="20" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)" 
                                               To="4" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                               To="-2" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" 
                                               To="0.04" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" 
                                               To="12" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.ShadowDepth)" 
                                               To="2" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                                               To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InteractiveButton" TargetType="Button">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                               To="1.05" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                               To="1.05" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                               To="1" Duration="0:0:0.1"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                               To="1" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="18,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CustomSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="8" Background="{TemplateBinding Background}" CornerRadius="4" VerticalAlignment="Center"/>
                            <Border x:Name="ProgressBorder" Height="8" Background="{TemplateBinding Foreground}" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource AccentColor}" BorderThickness="2.5" CornerRadius="10">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#3B82F6" Opacity="0.2" BlurRadius="6" ShadowDepth="0"/>
                                                    </Border.Effect>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ProgressBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="SwitchBorder" Width="48" Height="26" Background="{DynamicResource BorderColor}" CornerRadius="13">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                            </Border>
                            <Border x:Name="SwitchThumb" Width="22" Height="22" Background="{DynamicResource CardBackground}" CornerRadius="11" HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="4" ShadowDepth="1"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InteractiveNumberInput" TargetType="TextBox">
            <Setter Property="Width" Value="68"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{DynamicResource Background}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/>
                            </Border.Effect>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource TextTertiary}"/>
                                <Setter TargetName="InputBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Setter TargetName="InputBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3B82F6" Opacity="0.1" BlurRadius="20" ShadowDepth="4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InteractiveNumberInputSmall" TargetType="TextBox" BasedOn="{StaticResource InteractiveNumberInput}">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <Style x:Key="InteractiveSoundButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource HoverColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="Transparent" 
                                BorderThickness="1.5" 
                                CornerRadius="8" 
                                Padding="14,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 未选中时的悬停样式 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}" Value="False"/>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource BorderColor}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource TextTertiary}"/>
                            </MultiDataTrigger>
                            <!-- 选中时的悬停样式 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected}" Value="True"/>
                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentColorHover}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AccentColorHover}"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentColorHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{DynamicResource Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
                <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="MaxWidth" Value="6"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Width" Value="10"/>
                            <Setter Property="MaxWidth" Value="10"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Resources>
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollViewer">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ScrollContentPresenter Grid.Column="0" Content="{TemplateBinding Content}"/>
                                    <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1" 
                                               Orientation="Vertical" 
                                               Value="{TemplateBinding VerticalOffset}" 
                                               Maximum="{TemplateBinding ScrollableHeight}" 
                                               ViewportSize="{TemplateBinding ViewportHeight}" 
                                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                               Style="{StaticResource ThinScrollBar}"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Style>

            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top" MaxWidth="640">
                    <TextBlock Text="工欲善其事，必先利其器" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"
                               Margin="0,24,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="调整设置，让工具更适合你" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <Grid Margin="0,0,0,28" MaxWidth="440" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="ClockButton" Grid.Column="0" Content="时钟"
                                Background="{DynamicResource AccentColor}" Foreground="White"
                                Margin="0,0,12,0" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}"/>

                        <Button x:Name="SoundButton" Grid.Column="1" Content="声音"
                                Background="{DynamicResource HoverColor}" Foreground="{DynamicResource TextPrimary}"
                                Margin="0,0,12,0" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}"/>

                        <Button x:Name="OtherButton" Grid.Column="2" Content="其它"
                                Background="{DynamicResource HoverColor}" Foreground="{DynamicResource TextPrimary}"
                                Margin="0,0,0,0" Click="NavButton_Click" Style="{StaticResource NavButtonStyle}"/>
                    </Grid>

                    <StackPanel x:Name="ClockPage" Visibility="Visible">
                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <TextBlock Text="⏱️ 番茄钟时间设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="专注时间" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="每个番茄钟的专注时长" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox x:Name="WorkDurationInput" Style="{StaticResource InteractiveNumberInput}" Text="25"/>
                                        <TextBlock Text="分钟" FontSize="15" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="休息时间" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="每个番茄钟后的休息时长" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox x:Name="BreakDurationInput" Style="{StaticResource InteractiveNumberInput}" Text="5"/>
                                        <TextBlock Text="分钟" FontSize="15" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="长休息时间" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="完成多个番茄钟后的长休息时长" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox x:Name="LongBreakDurationInput" Style="{StaticResource InteractiveNumberInput}" Text="15"/>
                                        <TextBlock Text="分钟" FontSize="15" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="长休息间隔" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="完成多少个番茄钟后触发长休息" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox x:Name="SessionsBeforeLongBreakInput" Style="{StaticResource InteractiveNumberInput}" Text="4"/>
                                        <TextBlock Text="个" FontSize="15" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <TextBlock Text="⏱️ 计时器设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="倒计时默认时间" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="倒计时模式的默认时长" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox x:Name="CountdownDefaultDaysInput" Style="{StaticResource InteractiveNumberInputSmall}" Text="0" Margin="0,0,10,0"/>
                                        <TextBlock Text="天" FontSize="15" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="CountdownDefaultHoursInput" Style="{StaticResource InteractiveNumberInputSmall}" Text="0" Margin="10,0,10,0"/>
                                        <TextBlock Text="时" FontSize="15" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="CountdownDefaultMinutesInput" Style="{StaticResource InteractiveNumberInputSmall}" Text="5" Margin="10,0,10,0"/>
                                        <TextBlock Text="分" FontSize="15" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Center"/>
                                        <TextBox x:Name="CountdownDefaultSecondsInput" Style="{StaticResource InteractiveNumberInputSmall}" Text="0" Margin="10,0,0,0"/>
                                        <TextBlock Text="秒" FontSize="15" Foreground="{DynamicResource TextTertiary}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="SoundPage" Visibility="Collapsed">
                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <TextBlock Text="🔔 提示音设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启用提示音" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="番茄钟开始和结束时播放提示音" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="NotificationSoundEnabledCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>

                                <Grid Margin="0,0,0,20">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="提示音" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium" Margin="0,0,0,10"/>
                                    <ItemsControl x:Name="NotificationSoundItemsControl" Grid.Row="1" HorizontalAlignment="Left">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button x:Name="NotificationSoundButton" Content="{Binding NotificationSound.Name}" FontSize="14" FontWeight="Medium"
                                                        Margin="0,0,10,0" Click="NotificationSoundButton_Click" Height="40" MinWidth="90" Style="{StaticResource InteractiveSoundButton}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="音量" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <Slider x:Name="NotificationSoundVolumeSlider" Style="{StaticResource CustomSliderStyle}" 
                                                Minimum="0" Maximum="100" Value="80" Margin="0,10,24,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="NotificationSoundVolumeValue" Grid.Column="1" Text="80%" FontSize="16" Foreground="{DynamicResource TextTertiary}" 
                                               VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🌊 白噪声设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启用白噪声" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="专注时播放背景白噪声" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="WhiteNoisePlayButton" Grid.Column="1" 
                                            Width="44" Height="44" BorderThickness="0" 
                                            Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextSecondary}" 
                                            Margin="0,0,14,0" VerticalAlignment="Center" ToolTip="试听" Style="{StaticResource InteractiveButton}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="50" Background="{TemplateBinding Background}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Path x:Name="PlayPauseIcon" Data="M8,5.14V19.14L19,12.14L8,5.14Z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <CheckBox x:Name="WhiteNoiseEnabledCheckBox" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center" IsChecked="False"/>
                                </Grid>

                                <ItemsControl x:Name="WhiteNoiseItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Margin="0,0,10,10" Cursor="Hand">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="12" ShadowDepth="2"/>
                                                </Border.Effect>
                                                <Grid MouseEnter="WhiteNoiseContainer_MouseEnter" MouseLeave="WhiteNoiseContainer_MouseLeave" MouseLeftButtonDown="WhiteNoiseContainer_Click">
                                                    <Image Source="{Binding WhiteNoise.CoverImagePath, Converter={StaticResource StringToUriConverter}}" Stretch="UniformToFill" Width="Auto" Height="180"/>
                                                    <Border x:Name="WhiteNoiseMask" Background="{DynamicResource CardBackground}" Opacity="{Binding MaskOpacity}">
                                                        <Grid Margin="14,14,14,14" VerticalAlignment="Bottom">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding WhiteNoise.Name}" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <Slider x:Name="WhiteNoiseVolumeSlider" Style="{StaticResource CustomSliderStyle}"
                                                            Minimum="0" Maximum="100" Value="{Binding Volume, Mode=TwoWay}" Width="110" IsEnabled="True"
                                                            Margin="14,0,14,14" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                            ValueChanged="WhiteNoiseVolumeSlider_ValueChanged"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="OtherPage" Visibility="Collapsed">
                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="🧩 小组件设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="启用小组件" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="关闭后，任何地方都无法使用小组件" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="WidgetWindowEnabledCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="最小化时自动显示小组件" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="仅当启用小组件时生效" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoShowWidgetOnMinimizeCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center" IsChecked="True"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="窗口置顶" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="始终显示在其它窗口上方" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="WidgetWindowTopmostCheckBox" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                              VerticalAlignment="Center" IsChecked="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <TextBlock Text="🎨 外观设置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="主题" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBlock Text="选择应用程序的显示主题" FontSize="13" Foreground="{DynamicResource TextTertiary}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="LightThemeButton" Content="浅色" Style="{StaticResource InteractiveSoundButton}" Margin="0,0,10,0" Click="ThemeButton_Click"/>
                                        <Button x:Name="DarkThemeButton" Content="深色" Style="{StaticResource InteractiveSoundButton}" Click="ThemeButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource InteractiveCard}">
                            <StackPanel>
                                <TextBlock Text="💾 个人数据存储位置" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,24"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="数据存储路径" FontSize="15" Foreground="{DynamicResource TextSecondary}" FontWeight="Medium"/>
                                        <TextBox x:Name="StoragePathTextBox" Style="{StaticResource InteractiveNumberInput}" 
                                                 Width="Auto" HorizontalAlignment="Stretch" Margin="0,10,20,0"
                                                 Text=""/>
                                    </StackPanel>
                                    <Button x:Name="BrowseButton" Grid.Column="1" Content="浏览..." Style="{StaticResource BrowseButtonStyle}" 
                                            VerticalAlignment="Bottom" Margin="0,0,0,0" Click="BrowseButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>