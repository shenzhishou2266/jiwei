                                <Border x:Name="Cell_7_2" Grid.Row="7" Grid.Column="2" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_3" Grid.Row="7" Grid.Column="3" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_4" Grid.Row="7" Grid.Column="4" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_5" Grid.Row="7" Grid.Column="5" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_6" Grid.Row="7" Grid.Column="6" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_7" Grid.Row="7" Grid.Column="7" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_8" Grid.Row="7" Grid.Column="8" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_9" Grid.Row="7" Grid.Column="9" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_10" Grid.Row="7" Grid.Column="10" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_11" Grid.Row="7" Grid.Column="11" Style="{StaticResource CalendarCellStyle}"/>
                                <Border x:Name="Cell_7_12" Grid.Row="7" Grid.Column="12" Style="{StaticResource CalendarCellStyle}"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel x:Name="CalendarLegend" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InteractiveStatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="本周趋势" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="80"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel x:Name="WeeklyChart" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBlock Text="日" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="一" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="二" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="三" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="四" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="五" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                                <TextBlock Text="六" FontSize="13" Foreground="#9CA3AF" Width="68" TextAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InteractiveStatCard}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="数据汇总" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,16">
                                <TextBlock Text="本月累计" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="MonthlyHours" Text="0" FontSize="24" FontWeight="Bold" Foreground="#3B82F6"/>
                                    <TextBlock Text="小时" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                </StackPanel>
                                <TextBlock x:Name="MonthlyHoursSub" Text="本月数据" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,16">
                                <TextBlock Text="累计时长" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TotalHours" Text="0" FontSize="24" FontWeight="Bold" Foreground="#8B5CF6"/>
                                    <TextBlock Text="小时" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                </StackPanel>
                                <TextBlock x:Name="TotalHoursSub" Text="自使用以来" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0">
                                <TextBlock Text="累计个数" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TotalSessions" Text="0" FontSize="24" FontWeight="Bold" Foreground="#F97316"/>
                                    <TextBlock Text="个" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                </StackPanel>
                                <TextBlock x:Name="TotalSessionsSub" Text="暂无数据" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="日均时长" FontSize="12" Foreground="{DynamicResource TextTertiary}" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="AvgDailyHours" Text="0" FontSize="24" FontWeight="Bold" Foreground="#10B981"/>
                                    <TextBlock Text="小时" FontSize="12" Foreground="{DynamicResource TextTertiary}" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                </StackPanel>
                                <TextBlock x:Name="AvgDailyHoursSub" Text="平均每日专注" FontSize="11" Foreground="{DynamicResource TextTertiary}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
