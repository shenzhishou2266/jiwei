<Window x:Class="积微.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:积微.Views"
        xmlns:controls="clr-namespace:积微.Controls"
        mc:Ignorable="d"
        Title="积微"
        Icon="pack://application:,,,/Resources/icon/番茄.png"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,1,0">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5">
                <Button x:Name="HomeButton" Click="HomeButton_Click" Margin="0,0,0,10"
                        Width="40" Height="40" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundedButtonStyle}">
                    <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button.ToolTip>
                        <ToolTip Content="主页"/>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="StatsButton" Click="StatsButton_Click" Margin="0,10,0,10"
                        Width="40" Height="40" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundedButtonStyle}">
                    <Path Data="M3 3h18v18H3V3zm5 14h2V7H8v10zm4 0h2V5h-2v12zm4 0h2V9h-2v8z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button.ToolTip>
                        <ToolTip Content="统计"/>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="GoalsButton" Click="GoalsButton_Click" Margin="0,10,0,10"
                        Width="40" Height="40" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundedButtonStyle}">
                    <Path Data="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button.ToolTip>
                        <ToolTip Content="目标"/>
                    </Button.ToolTip>
                </Button>
                <Button x:Name="SettingsButton" Click="SettingsButton_Click" Margin="0,10,0,0"
                        Width="40" Height="40" BorderThickness="0"
                        Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                        Style="{StaticResource RoundedButtonStyle}">
                    <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" Fill="{DynamicResource TextSecondary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button.ToolTip>
                        <ToolTip Content="设置"/>
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </Border>
        
        <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ContentControl x:Name="ContentArea" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
